# Required
OPENAI_API_KEY=

# Optional (skip if you don't want Supermemory)
SUPERMEMORY_API_KEY=
SUPERMEMORY_OPENCLAW_API_KEY=

# Optional
ANTHROPIC_API_KEY=
BRAVE_API_KEY=
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_IMAGE=openclaw:local

# Optional advanced
OPENCLAW_REPO_URL=https://github.com/openclaw/openclaw.git
OPENCLAW_REPO_BRANCH=main
OPENCLAW_SRC_DIR=
OPENCLAW_USE_LOCAL_SOURCE=auto
OPENCLAW_DOCKER_APT_PACKAGES=chromium git python3 python3-pip sudo
COMPOSE_PROJECT_NAME=openclaw-easy
OPENCLAW_SAFE_PROJECT_NAME=openclaw-easy
OPENCLAW_DEFAULT_CHANNEL_PLUGINS=telegram,whatsapp
OPENCLAW_ALWAYS_ALLOW_EXEC=false
OPENCLAW_ENABLE_MISSION_CONTROL=true
OPENCLAW_ENABLE_COMMAND_CENTER=false
OPENCLAW_MISSION_CONTROL_REPO_URL=https://github.com/abhi1693/openclaw-mission-control.git
OPENCLAW_MISSION_CONTROL_REPO_BRANCH=master
OPENCLAW_MISSION_CONTROL_SRC_DIR=
OPENCLAW_MISSION_CONTROL_FRONTEND_PORT=3310
OPENCLAW_MISSION_CONTROL_BACKEND_PORT=8310
OPENCLAW_MISSION_CONTROL_POSTGRES_PORT=55432
OPENCLAW_MISSION_CONTROL_REDIS_PORT=56379
OPENCLAW_MISSION_CONTROL_POSTGRES_DB=mission_control
OPENCLAW_MISSION_CONTROL_POSTGRES_USER=postgres
OPENCLAW_MISSION_CONTROL_POSTGRES_PASSWORD=
OPENCLAW_MISSION_CONTROL_AUTOCONFIG_GATEWAY=true
OPENCLAW_MISSION_CONTROL_SYNC_TEMPLATES=true
OPENCLAW_MISSION_CONTROL_GATEWAY_NAME=OpenClaw Docker Gateway
OPENCLAW_MISSION_CONTROL_GATEWAY_WORKSPACE_ROOT=/home/node/.openclaw
OPENCLAW_MISSION_CONTROL_GATEWAY_ID=
OPENCLAW_MISSION_CONTROL_GATEWAY_URL=
OPENCLAW_MISSION_CONTROL_BASE_URL=
OPENCLAW_MISSION_CONTROL_SEED_BOARD=true
OPENCLAW_MISSION_CONTROL_BOARD_NAME=Main Board
OPENCLAW_MISSION_CONTROL_BOARD_SLUG=main-board
OPENCLAW_MISSION_CONTROL_BOARD_DESCRIPTION=Primary board for OpenClaw automation.
OPENCLAW_MISSION_CONTROL_BOARD_PERSPECTIVE=Pragmatic execution: prioritize outcomes, clear ownership, and fast feedback loops.
OPENCLAW_MISSION_CONTROL_BOARD_TYPE=goal
OPENCLAW_MISSION_CONTROL_BOARD_OBJECTIVE=
OPENCLAW_MISSION_CONTROL_BOARD_SUCCESS_METRICS_JSON=
OPENCLAW_MISSION_CONTROL_BOARD_TARGET_DATE=
OPENCLAW_MISSION_CONTROL_BOARD_GOAL_CONFIRMED=false
OPENCLAW_MISSION_CONTROL_BOARD_GOAL_SOURCE=
OPENCLAW_MISSION_CONTROL_BOARD_GROUP_ID=
OPENCLAW_MISSION_CONTROL_BOARD_MAX_AGENTS=1
OPENCLAW_MISSION_CONTROL_BOARD_CONFIG_JSON=
OPENCLAW_MISSION_CONTROL_BOARD_CONFIG_FILE=
OPENCLAW_MISSION_CONTROL_SEED_BOARD_PACK=true
OPENCLAW_MISSION_CONTROL_BOARD_PACK_CONFIG_JSON=
OPENCLAW_MISSION_CONTROL_BOARD_PACK_CONFIG_FILE=board.pack.json
OPENCLAW_COMMAND_CENTER_REPO_URL=https://github.com/jontsai/openclaw-command-center.git
OPENCLAW_COMMAND_CENTER_REPO_BRANCH=main
OPENCLAW_COMMAND_CENTER_SRC_DIR=
OPENCLAW_COMMAND_CENTER_PORT=3340
OPENCLAW_COMMAND_CENTER_AUTH_MODE=token
OPENCLAW_COMMAND_CENTER_TOKEN=
OPENCLAW_COMMAND_CENTER_ALLOWED_USERS=*
OPENCLAW_COMMAND_CENTER_ALLOWED_IPS=127.0.0.1,::1
OPENCLAW_COMMAND_CENTER_OPENCLAW_PROFILE=

# Auto-generated on first start if empty
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_ENABLE_SUPERMEMORY=
OPENCLAW_MISSION_CONTROL_LOCAL_AUTH_TOKEN=
